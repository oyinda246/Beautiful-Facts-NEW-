<!DOCTYPE html>
<html>
<head>
    <title>Beautiful Life Facts 💛</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            background: linear-gradient(to right, #ffecd2, #fcb69f);
            padding: 50px;
        }

        h1 {
            color: #333;
        }

        p {
            font-size: 18px;
            color: #444;
        }

        button {
            padding: 12px 25px;
            font-size: 16px;
            background-color: #6c63ff;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }

        button:hover {
            background-color: #574fd6;
        }

        #fact {
            margin-top: 20px;
            font-size: 20px;
            font-weight: bold;
            color: #222;
        }
    </style>
</head>

<body>

    <h1>🌸 Beautiful Life Facts 💛</h1>
    <p>Click the button to see a gentle reminder about life ✨</p>

    <button onclick="showFact()">Show Reminder</button>

    <p id="fact"></p>

    <script>
        function showFact() {
            const facts = [
                "Life doesn’t have to be perfect to be beautiful 🌸",
                "Every tough moment you survive makes you stronger 💪",
                "Small moments are what make life meaningful ☀️",
                "You are growing, even when it feels slow 🌱",
                "Someone, somewhere, is grateful you exist 💛",
                "Healing takes time, and that’s okay 🌻",
                "Your current situation is not your final destination 🌙",
                "You are allowed to start again ✨",
                "Life changes — and sometimes that change is what you need 🌊",
                "You don’t have to have everything figured out 💫"
            ];

            let random = Math.floor(Math.random() * facts.length);
            document.getElementById("fact").innerText = facts[random];
        }
    </script>

</body>
</html>
